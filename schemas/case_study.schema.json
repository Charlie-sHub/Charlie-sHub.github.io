{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case Study",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "case_study" },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "source_path": { "type": "string", "minLength": 1 },
        "incident_code": { "type": "string", "minLength": 1 }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "attack_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tactics", "techniques", "procedure_examples"],
      "properties": {
        "tactics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "techniques": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "procedure_examples": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "atlas_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "tactics_and_techniques": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "procedure_examples": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "indicators": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "incident_overview",
        "adversary_objectives",
        "attack_mapping",
        "defensive_analysis",
        "lessons_learned",
        "reflection",
        "references"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "incident_overview": { "type": "string", "minLength": 1 },
        "adversary_objectives": { "type": "string", "minLength": 1 },
        "attack_mapping": { "$ref": "#/$defs/attack_mapping" },
        "defensive_mapping": { "type": "string", "minLength": 1 },
        "atlas_mapping": { "$ref": "#/$defs/atlas_mapping" },
        "indicators": { "$ref": "#/$defs/indicators" },
        "defensive_analysis": { "type": "string", "minLength": 1 },
        "lessons_learned": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "reflection": { "type": "string", "minLength": 1 },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    }
  }
}
