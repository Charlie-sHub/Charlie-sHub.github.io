{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case Study",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "slug_string": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_path_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "title_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\r\n]+$"
    },
    "line_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "long_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "url_string": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "pattern": "^[^\r\n]+$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "case_study" },
        "slug": { "$ref": "#/$defs/slug_string" },
        "source_path": { "$ref": "#/$defs/source_path_string" },
        "incident_code": { "$ref": "#/$defs/line_text" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "url": { "$ref": "#/$defs/url_string" }
      }
    },
    "attack_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tactics", "techniques", "procedure_examples"],
      "properties": {
        "tactics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "techniques": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "procedure_examples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        }
      }
    },
    "atlas_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "$ref": "#/$defs/long_text" },
        "tactics_and_techniques": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "procedure_examples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        }
      }
    },
    "indicators": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "summary": { "$ref": "#/$defs/long_text" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "incident_overview",
        "adversary_objectives",
        "attack_mapping",
        "defensive_analysis",
        "lessons_learned",
        "reflection",
        "references"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "summary": { "$ref": "#/$defs/long_text" },
        "incident_overview": { "$ref": "#/$defs/long_text" },
        "adversary_objectives": { "$ref": "#/$defs/long_text" },
        "attack_mapping": { "$ref": "#/$defs/attack_mapping" },
        "defensive_mapping": { "$ref": "#/$defs/long_text" },
        "atlas_mapping": { "$ref": "#/$defs/atlas_mapping" },
        "indicators": { "$ref": "#/$defs/indicators" },
        "defensive_analysis": { "$ref": "#/$defs/long_text" },
        "lessons_learned": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "reflection": { "$ref": "#/$defs/long_text" },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    }
  }
}
