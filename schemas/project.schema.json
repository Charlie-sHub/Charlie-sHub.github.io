{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "year_month": {
      "type": "string",
      "minLength": 7,
      "maxLength": 7,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "slug_string": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_path_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "title_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\r\n]+$"
    },
    "line_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "long_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "media_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/media/[^\\r\\n]+$"
    },
    "nullable_media_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/media_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path", "start_date", "end_date", "is_ongoing"],
      "properties": {
        "type": { "const": "project" },
        "slug": { "$ref": "#/$defs/slug_string" },
        "source_path": { "$ref": "#/$defs/source_path_string" },
        "start_date": { "$ref": "#/$defs/year_month" },
        "end_date": {
          "anyOf": [
            { "$ref": "#/$defs/year_month" },
            { "type": "null" }
          ]
        },
        "is_ongoing": { "type": "boolean" }
      }
    },
    "link_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048,
          "pattern": "^[^\r\n]+$"
        }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "role_and_scope",
        "product_context",
        "stack",
        "implementation",
        "outcomes"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "summary": { "$ref": "#/$defs/long_text" },
        "thumbnailPath": { "$ref": "#/$defs/nullable_media_asset_path" },
        "heroImagePath": { "$ref": "#/$defs/nullable_media_asset_path" },
        "galleryImagePaths": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/media_asset_path" }
        },
        "role_and_scope": { "$ref": "#/$defs/long_text" },
        "product_context": { "$ref": "#/$defs/long_text" },
        "stack": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/line_text" }
        },
        "implementation": { "$ref": "#/$defs/long_text" },
        "security_and_quality": { "$ref": "#/$defs/long_text" },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link_item" }
        }
      }
    }
  }
}
