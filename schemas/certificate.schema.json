{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Certificate",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "year_month": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "media_asset_path": {
      "type": "string",
      "pattern": "^assets/media/.+"
    },
    "document_asset_path": {
      "type": "string",
      "pattern": "^assets/documents/.+"
    },
    "nullable_media_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/media_asset_path" },
        { "type": "null" }
      ]
    },
    "nullable_document_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/document_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path", "earned_date"],
      "properties": {
        "type": { "const": "certificate" },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "source_path": { "type": "string", "minLength": 1 },
        "earned_date": { "$ref": "#/$defs/year_month" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "credential_details",
        "knowledge_areas",
        "learning_outcomes"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "badgeImagePath": { "$ref": "#/$defs/nullable_media_asset_path" },
        "certificatePdfPath": { "$ref": "#/$defs/nullable_document_asset_path" },
        "credential_details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["issuer", "credential_type", "level"],
          "properties": {
            "issuer": { "type": "string", "minLength": 1 },
            "platform": { "type": "string", "minLength": 1 },
            "credential_type": { "type": "string", "minLength": 1 },
            "level": { "type": "string", "minLength": 1 },
            "program_size": { "type": "string", "minLength": 1 },
            "program_scope": { "type": "string", "minLength": 1 },
            "focus": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "intended_audience": { "type": "string", "minLength": 1 },
            "update_note": { "type": "string", "minLength": 1 }
          }
        },
        "knowledge_areas": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "tools_and_frameworks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "learning_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "proof": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    }
  }
}
