{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Certificate",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "year_month": {
      "type": "string",
      "minLength": 7,
      "maxLength": 7,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "slug_string": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_path_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "title_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\r\n]+$"
    },
    "line_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "long_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "url_string": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]://[^\\r\\n]+$"
    },
    "media_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/media/[^\\r\\n]+$"
    },
    "document_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/documents/[^\\r\\n]+$"
    },
    "nullable_media_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/media_asset_path" },
        { "type": "null" }
      ]
    },
    "nullable_document_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/document_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path", "earned_date"],
      "properties": {
        "type": { "const": "certificate" },
        "slug": { "$ref": "#/$defs/slug_string" },
        "source_path": { "$ref": "#/$defs/source_path_string" },
        "earned_date": { "$ref": "#/$defs/year_month" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "url": { "$ref": "#/$defs/url_string" }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "credential_details",
        "knowledge_areas",
        "learning_outcomes"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "summary": { "$ref": "#/$defs/long_text" },
        "badgeImagePath": { "$ref": "#/$defs/nullable_media_asset_path" },
        "certificatePdfPath": { "$ref": "#/$defs/nullable_document_asset_path" },
        "credential_details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["issuer", "credential_type", "level"],
          "properties": {
            "issuer": { "$ref": "#/$defs/line_text" },
            "platform": { "$ref": "#/$defs/line_text" },
            "credential_type": { "$ref": "#/$defs/line_text" },
            "level": { "$ref": "#/$defs/line_text" },
            "program_size": { "$ref": "#/$defs/line_text" },
            "program_scope": { "$ref": "#/$defs/line_text" },
            "focus": { "$ref": "#/$defs/line_text" },
            "version": { "$ref": "#/$defs/line_text" },
            "intended_audience": { "$ref": "#/$defs/line_text" },
            "update_note": { "$ref": "#/$defs/line_text" }
          }
        },
        "knowledge_areas": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "tools_and_frameworks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "learning_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "proof": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    }
  }
}
