{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "About Me",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "slug_string": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_path_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "title_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\r\n]+$"
    },
    "line_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "short_paragraph_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320
    },
    "nullable_short_paragraph_text": {
      "anyOf": [
        { "$ref": "#/$defs/short_paragraph_text" },
        { "type": "null" }
      ]
    },
    "long_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "media_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/media/[^\\r\\n]+$"
    },
    "nullable_media_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/media_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "about_me" },
        "slug": { "$ref": "#/$defs/slug_string" },
        "source_path": { "$ref": "#/$defs/source_path_string" }
      }
    },
    "skill_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "items"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/line_text" }
        }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "who_i_am_professionally",
        "current_positioning",
        "development_background",
        "security_direction",
        "strengths_and_working_style",
        "selected_skills_and_tools",
        "how_i_build_software",
        "how_development_and_security_connect"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "professional_summary_short": {
          "$ref": "#/$defs/nullable_short_paragraph_text"
        },
        "profile_image_path": {
          "$ref": "#/$defs/nullable_media_asset_path"
        },
        "who_i_am_professionally": { "$ref": "#/$defs/long_text" },
        "current_positioning": { "$ref": "#/$defs/long_text" },
        "development_background": { "$ref": "#/$defs/long_text" },
        "security_direction": { "$ref": "#/$defs/long_text" },
        "strengths_and_working_style": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "selected_skills_and_tools": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill_group" }
        },
        "how_i_build_software": { "$ref": "#/$defs/long_text" },
        "how_development_and_security_connect": {
          "$ref": "#/$defs/long_text"
        }
      }
    }
  }
}
