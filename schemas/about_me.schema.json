{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "About Me",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "about_me" },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "source_path": { "type": "string", "minLength": 1 }
      }
    },
    "skill_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "items"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "who_i_am_professionally",
        "current_positioning",
        "development_background",
        "security_direction",
        "strengths_and_working_style",
        "selected_skills_and_tools",
        "how_i_build_software",
        "how_development_and_security_connect"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "who_i_am_professionally": { "type": "string", "minLength": 1 },
        "current_positioning": { "type": "string", "minLength": 1 },
        "development_background": { "type": "string", "minLength": 1 },
        "security_direction": { "type": "string", "minLength": 1 },
        "strengths_and_working_style": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "selected_skills_and_tools": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill_group" }
        },
        "how_i_build_software": { "type": "string", "minLength": 1 },
        "how_development_and_security_connect": { "type": "string", "minLength": 1 }
      }
    }
  }
}
