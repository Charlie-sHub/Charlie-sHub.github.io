{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resume",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "year_month": {
      "type": "string",
      "minLength": 7,
      "maxLength": 7,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "slug_string": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_path_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "title_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\r\n]+$"
    },
    "line_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "email_address_string": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
    },
    "long_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "url_string": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]://[^\\r\\n]+$"
    },
    "document_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/documents/[^\\r\\n]+$"
    },
    "nullable_document_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/document_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "resume" },
        "slug": { "$ref": "#/$defs/slug_string" },
        "source_path": { "$ref": "#/$defs/source_path_string" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "kind": {
          "type": "string",
          "enum": [
            "external",
            "github",
            "linkedin",
            "portfolio",
            "repository",
            "documentation",
            "credential",
            "resume"
          ]
        },
        "url": { "$ref": "#/$defs/url_string" }
      }
    },
    "skill_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "items"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/line_text" }
        }
      }
    },
    "experience_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "location", "start_date", "end_date", "is_ongoing", "highlights"],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "organization": { "$ref": "#/$defs/line_text" },
        "location": { "$ref": "#/$defs/line_text" },
        "start_date": { "$ref": "#/$defs/year_month" },
        "end_date": {
          "anyOf": [
            { "$ref": "#/$defs/year_month" },
            { "type": "null" }
          ]
        },
        "is_ongoing": { "type": "boolean" },
        "highlights": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        }
      }
    },
    "education_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "institution", "location", "start_date", "end_date"],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "institution": { "$ref": "#/$defs/line_text" },
        "location": { "$ref": "#/$defs/line_text" },
        "start_date": { "$ref": "#/$defs/year_month" },
        "end_date": { "$ref": "#/$defs/year_month" }
      }
    },
    "language_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "proficiency"],
      "properties": {
        "language": { "$ref": "#/$defs/line_text" },
        "proficiency": { "$ref": "#/$defs/language_proficiency_value" }
      }
    },
    "language_proficiency_value": {
      "type": "string",
      "enum": ["Native", "A1", "A2", "B1", "B2", "C1", "C2"]
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "location",
        "summary",
        "contact_links",
        "core_skills",
        "professional_experience",
        "education",
        "languages"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/line_text" },
        "location": { "$ref": "#/$defs/line_text" },
        "summary": { "$ref": "#/$defs/long_text" },
        "direct_email_address": { "$ref": "#/$defs/email_address_string" },
        "resumePdfPath": { "$ref": "#/$defs/nullable_document_asset_path" },
        "contact_links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        },
        "core_skills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill_group" }
        },
        "professional_experience": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/experience_item" }
        },
        "education": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/education_item" }
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/language_item" }
        }
      }
    }
  }
}
