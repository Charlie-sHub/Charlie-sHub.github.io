{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resume",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "year_month": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "document_asset_path": {
      "type": "string",
      "pattern": "^assets/documents/.+"
    },
    "nullable_document_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/document_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "resume" },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "source_path": { "type": "string", "minLength": 1 }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "skill_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "items"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "experience_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "location", "start_date", "end_date", "is_ongoing", "highlights"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "organization": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "start_date": { "$ref": "#/$defs/year_month" },
        "end_date": {
          "anyOf": [
            { "$ref": "#/$defs/year_month" },
            { "type": "null" }
          ]
        },
        "is_ongoing": { "type": "boolean" },
        "highlights": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "education_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "institution", "location", "start_date", "end_date"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "institution": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "start_date": { "$ref": "#/$defs/year_month" },
        "end_date": { "$ref": "#/$defs/year_month" }
      }
    },
    "language_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "proficiency"],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "proficiency": { "type": "string", "minLength": 1 }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "location",
        "summary",
        "contact_links",
        "core_skills",
        "professional_experience",
        "education",
        "languages"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "resumePdfPath": { "$ref": "#/$defs/nullable_document_asset_path" },
        "contact_links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        },
        "core_skills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill_group" }
        },
        "professional_experience": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/experience_item" }
        },
        "education": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/education_item" }
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/language_item" }
        }
      }
    }
  }
}
