{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Content Index Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "$defs": {
    "index_file_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\r\\n]+\\.json$"
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": { "$ref": "#/$defs/index_file_name" },
        "order": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    }
  }
}
