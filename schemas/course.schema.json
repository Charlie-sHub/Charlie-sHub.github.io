{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Course",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "content"],
  "$defs": {
    "slug_string": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_path_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "title_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\r\n]+$"
    },
    "line_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\r\n]+$"
    },
    "long_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "url_string": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "pattern": "^[^\r\n]+$"
    },
    "media_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/media/[^\\r\\n]+$"
    },
    "document_asset_path": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^assets/documents/[^\\r\\n]+$"
    },
    "nullable_media_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/media_asset_path" },
        { "type": "null" }
      ]
    },
    "nullable_document_asset_path": {
      "anyOf": [
        { "$ref": "#/$defs/document_asset_path" },
        { "type": "null" }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug", "source_path"],
      "properties": {
        "type": { "const": "course" },
        "slug": { "$ref": "#/$defs/slug_string" },
        "source_path": { "$ref": "#/$defs/source_path_string" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "$ref": "#/$defs/line_text" },
        "url": { "$ref": "#/$defs/url_string" }
      }
    }
  },
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "course_details", "topics_covered", "relevance"],
      "properties": {
        "title": { "$ref": "#/$defs/title_text" },
        "summary": { "$ref": "#/$defs/long_text" },
        "badgeImagePath": { "$ref": "#/$defs/nullable_media_asset_path" },
        "certificatePdfPath": { "$ref": "#/$defs/nullable_document_asset_path" },
        "course_details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "platform", "format", "level"],
          "properties": {
            "provider": { "$ref": "#/$defs/line_text" },
            "platform": { "$ref": "#/$defs/line_text" },
            "format": { "$ref": "#/$defs/line_text" },
            "level": { "$ref": "#/$defs/line_text" },
            "program_context": { "$ref": "#/$defs/line_text" }
          }
        },
        "topics_covered": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "relevance": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "key_takeaways": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/long_text" }
        },
        "proof": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    }
  }
}
